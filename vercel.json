{
  "framework": "vite",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "devCommand": "bun run dev",
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_SERVER_URL": "https://ai-agent-server-production-d28a.up.railway.app"
  }
}
