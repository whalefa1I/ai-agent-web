{
  "name": "happy-client",
  "version": "1.0.0",
  "private": true,
  "description": "Happy AI Client - 支持 App 和 Web 的 AI 助手界面",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:app": "vite build --mode app",
    "build:web": "vite build --mode web",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "marked": "^14.0.0",
    "highlight.js": "^11.10.0",
    "ws": "^8.18.0",
    "lucide-vue-next": "^0.453.0",
    "@vueuse/core": "^11.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "vite": "^5.4.0",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
